name: dockercompose10944854202728988959
services:
  cesizen:
    build:
      context: C:\Users\Valentin Waultier\Desktop\Cours\Bachelor\Projet Individuel CESIZen\CESIZen
      dockerfile: CESIZen/Dockerfile
      args:
        BUILD_CONFIGURATION: Debug
        LAUNCHING_FROM_VS: "true"
      labels:
        com.microsoft.created-by: visual-studio
        com.microsoft.visual-studio.project-name: CESIZen
      target: base
    container_name: cesizen-web
    depends_on:
      sqlserver:
        condition: service_healthy
        required: true
    entrypoint:
      - dotnet
      - --roll-forward
      - Major
      - /VSTools/DistrolessHelper/DistrolessHelper.dll
      - --wait
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      ASPNETCORE_HTTPS_PORTS: "8081"
      ASPNETCORE_LOGGING__CONSOLE__DISABLECOLORS: "true"
      ConnectionStrings__DefaultConnection: Server=sqlserver;Database=CESIZen;User Id=sa;Password=CesiZen123!;TrustServerCertificate=true;MultipleActiveResultSets=true
      DOTNET_USE_POLLING_FILE_WATCHER: "1"
      NUGET_FALLBACK_PACKAGES: /.nuget/fallbackpackages
    image: cesizen:dev
    labels:
      com.microsoft.visualstudio.debuggee.arguments: ' --additionalProbingPath /.nuget/packages --additionalProbingPath /.nuget/fallbackpackages  "/app/bin/Debug/net8.0/CESIZen.dll"'
      com.microsoft.visualstudio.debuggee.killprogram: dotnet --roll-forward Major /VSTools/DistrolessHelper/DistrolessHelper.dll --stop dotnet
      com.microsoft.visualstudio.debuggee.program: dotnet
      com.microsoft.visualstudio.debuggee.workingdirectory: /app
    networks:
      cesizen-network: null
    ports:
      - mode: ingress
        target: 8080
        published: "5057"
        protocol: tcp
      - mode: ingress
        target: 8081
        published: "7214"
        protocol: tcp
      - mode: ingress
        target: 8080
        protocol: tcp
      - mode: ingress
        target: 8081
        protocol: tcp
    restart: unless-stopped
    tty: true
    volumes:
      - type: bind
        source: C:\Users\Valentin Waultier\AppData\Roaming\Microsoft\UserSecrets
        target: /home/app/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Valentin Waultier\AppData\Roaming\Microsoft\UserSecrets
        target: /root/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Valentin Waultier\AppData\Roaming\ASP.NET\Https
        target: /home/app/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Valentin Waultier\AppData\Roaming\ASP.NET\Https
        target: /root/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Valentin Waultier\Desktop\Cours\Bachelor\Projet Individuel CESIZen\CESIZen\CESIZen
        target: /app
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Valentin Waultier\Desktop\Cours\Bachelor\Projet Individuel CESIZen\CESIZen
        target: /src
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Valentin Waultier\vsdbg\vs2017u5
        target: /remote_debugger
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\Valentin Waultier\.nuget\packages
        target: /.nuget/packages
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Program Files (x86)\Microsoft Visual Studio\Shared\NuGetPackages
        target: /.nuget/fallbackpackages
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Program Files\Microsoft Visual Studio\2022\Community\MSBuild\Sdks\Microsoft.Docker.Sdk\tools\linux-x64\net8.0
        target: /VSTools
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Program Files\Microsoft Visual Studio\2022\Community\Common7\IDE\CommonExtensions\Microsoft\HotReload
        target: /HotReloadAgent
        read_only: true
        bind:
          create_host_path: true
  sqlserver:
    container_name: cesizen-sqlserver
    environment:
      ACCEPT_EULA: "Y"
      MSSQL_PID: Express
      SA_PASSWORD: CesiZen123!
    healthcheck:
      test:
        - CMD-SHELL
        - /opt/mssql-tools/bin/sqlcmd -S localhost -U sa -P CesiZen123! -Q 'SELECT 1'
      timeout: 10s
      interval: 30s
      retries: 5
      start_period: 1m0s
    image: mcr.microsoft.com/mssql/server:2022-latest
    networks:
      cesizen-network: null
    ports:
      - mode: ingress
        target: 1433
        published: "1433"
        protocol: tcp
    volumes:
      - type: volume
        source: sqlserver_data
        target: /var/opt/mssql
        volume: {}
networks:
  cesizen-network:
    name: dockercompose10944854202728988959_cesizen-network
    driver: bridge
volumes:
  sqlserver_data:
    name: dockercompose10944854202728988959_sqlserver_data